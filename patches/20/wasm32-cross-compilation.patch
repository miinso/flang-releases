+/// Rewrite an integer type to match the target pointer width when it was
+/// generated using the host data model. On x86-64 hosts pointers are 8 bytes,
+/// but for ILP32 targets (wasm32) they are 4.
+inline mlir::Type fixupIntTypeForTarget(mlir::Type ty, unsigned hostPtrBits,
+                                        unsigned targetPtrBits,
+                                        mlir::MLIRContext *ctx) {
+  if (auto intTy = mlir::dyn_cast<mlir::IntegerType>(ty)) {
+    if (intTy.getWidth() == hostPtrBits && targetPtrBits < hostPtrBits)
+      return mlir::IntegerType::get(ctx, targetPtrBits);
+  }
+  if (auto refTy = mlir::dyn_cast<fir::ReferenceType>(ty))
+    return fir::ReferenceType::get(
+        fixupIntTypeForTarget(refTy.getEleTy(), hostPtrBits, targetPtrBits, ctx));
+  return ty;
+}
+
+/// Rewrite a FunctionType so that parameters/results whose width matches
+/// the host pointer width are narrowed to the target pointer width when
+/// cross-compiling to an ILP32 target.
+inline mlir::FunctionType fixupFuncTypeForTarget(mlir::FunctionType funTy,
+                                                  unsigned hostPtrBits,
+                                                  unsigned targetPtrBits,
+                                                  mlir::MLIRContext *ctx) {
+  if (targetPtrBits >= hostPtrBits)
+    return funTy;
+  llvm::SmallVector<mlir::Type> argTys;
+  for (auto t : funTy.getInputs())
+    argTys.push_back(fixupIntTypeForTarget(t, hostPtrBits, targetPtrBits, ctx));
+  llvm::SmallVector<mlir::Type> resTys;
+  for (auto t : funTy.getResults())
+    resTys.push_back(fixupIntTypeForTarget(t, hostPtrBits, targetPtrBits, ctx));
+  return mlir::FunctionType::get(ctx, argTys, resTys);
+}
